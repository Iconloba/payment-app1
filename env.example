# -------------------------------------------------------
# .env.example — Copy this to a file named ".env" and
# fill in your real Stripe keys before running locally.
# NEVER commit your actual .env file to GitHub.
# -------------------------------------------------------

# Your Stripe SECRET key (starts with sk_test_ for test mode)
# Found at: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_KEY

# Your deployed site URL (no trailing slash)
# Example: https://your-app-name.onrender.com
# Leave blank locally — the app auto-detects it.
BASE_URL=
